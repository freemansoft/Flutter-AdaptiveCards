{
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "TextBlock",
      "text": "Upper: ${toUpper(user.name)}"
    },
    {
      "type": "TextBlock",
      "text": "Min: ${min(user.age, 30)}"
    },
    {
      "type": "TextBlock",
      "text": "Rounded: ${round(user.score)}"
    }
  ]
}
