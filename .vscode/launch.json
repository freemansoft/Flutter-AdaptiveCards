{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Widgetbook - Current",
      "type": "dart",
      "request": "launch",
      "flutterMode": "debug",
      "cwd": "${workspaceFolder}/widgetbook",
      "program": "lib/main.dart",
      "args": []
    },
    {
      // Sections with images may fail in chrome because of HTTPS CORS issues
      // Use --disable-web-security to disable CORS
      "name": "Widgetbook - Web",
      "type": "dart",
      "request": "launch",
      "flutterMode": "debug",
      "cwd": "${workspaceFolder}/widgetbook",
      "program": "lib/main.dart",
      "args": [
        "--web-browser-flag=--disable-web-security",
        "-d",
        "chrome",
        "--web-port",
        "3000"
      ]
    },
    {
      "name": "Adaptive Explorer - Current",
      "type": "dart",
      "request": "launch",
      "flutterMode": "debug",
      "cwd": "${workspaceFolder}/adaptive_explorer",
      "program": "lib/main.dart",
      "args": []
    },
    {
      "name": "Adaptive Chat Client - Current",
      "type": "dart",
      "request": "launch",
      "flutterMode": "debug",
      "cwd": "${workspaceFolder}/adaptive_chat_client",
      "program": "lib/main.dart",
      "args": []
    },
    {
      // Talks to the FastAPI server on :8000. --disable-web-security avoids
      // local CORS friction when running the app in Chrome during development.
      "name": "Adaptive Chat Client - Web",
      "type": "dart",
      "request": "launch",
      "flutterMode": "debug",
      "cwd": "${workspaceFolder}/adaptive_chat_client",
      "program": "lib/main.dart",
      "args": [
        "--web-browser-flag=--disable-web-security",
        "-d",
        "chrome",
        "--web-port",
        "3000"
      ]
    },
    {
      // Uses the project's Python venv; run `python3 -m venv .venv &&
      // .venv/bin/pip install -r requirements.txt` in adaptive_chat_server
      // first. On Windows use .venv/Scripts/python.exe.
      "name": "Adaptive Chat Server (echo)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/adaptive_chat_server",
      "python": "${workspaceFolder}/adaptive_chat_server/.venv/bin/python"
    },
    {
      // Runs the CLI entrypoint (python -m app) which selects OllamaResponder
      // from --ollama-url. Requires a local Ollama (`ollama serve`) with the
      // model pulled (`ollama pull llama3.2`).
      "name": "Adaptive Chat Server (Ollama llama3.2)",
      "type": "debugpy",
      "request": "launch",
      "module": "app",
      "args": [
        "--ollama-url",
        "http://127.0.0.1:11434",
        "--log-level",
        "debug",
        "--ollama-model",
        "llama3.2",
        "--num-ctx",
        "16384",
        "--history-turns",
        "10",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/adaptive_chat_server",
      "python": "${workspaceFolder}/adaptive_chat_server/.venv/bin/python"
    },
    {
      // Runs the CLI entrypoint (python -m app) which selects OllamaResponder
      // from --ollama-url. Requires a local Ollama (`ollama serve`) with the
      // model pulled (`ollama pull gpt-oss:20b`).
      "name": "Adaptive Chat Server (Ollama gpt-oss:20b)",
      "type": "debugpy",
      "request": "launch",
      "module": "app",
      "args": [
        "--ollama-url",
        "http://127.0.0.1:11434",
        "--log-level",
        "debug",
        "--ollama-model",
        "gpt-oss:20b",
        "--num-ctx",
        "16384",
        "--history-turns",
        "10",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/adaptive_chat_server",
      "python": "${workspaceFolder}/adaptive_chat_server/.venv/bin/python"
    },
    {
      // Runs the CLI entrypoint (python -m app) which selects OllamaResponder
      // from --ollama-url. Requires a local Ollama (`ollama serve`) with the
      // model pulled (`ollama pull qwen3.5:9b`).
      "name": "Adaptive Chat Server (Ollama qwen3.5:9b)",
      "type": "debugpy",
      "request": "launch",
      "module": "app",
      "args": [
        "--ollama-url",
        "http://127.0.0.1:11434",
        "--log-level",
        "debug",
        "--ollama-model",
        "gpt-oss:20b",
        "--num-ctx",
        "16384",
        "--history-turns",
        "10",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/adaptive_chat_server",
      "python": "${workspaceFolder}/adaptive_chat_server/.venv/bin/python"
    },
    {
      // Card mode with llama3.2: same as the llama3.2 target but points the
      // responder at the bundled card system prompt (app/card_system_prompt.txt)
      // instead of the default, so the model replies with Adaptive Card fragments
      // rendered inside the chat bubble. Prompt re-read per request; path is
      // relative to cwd. Echo mode ignores the system prompt, so Ollama-only.
      // --json-format schema is the default (docs/superpowers/specs/2026-07-23-
      // ollama-structured-json-output-design.md) but named explicitly here since
      // this target's whole purpose is exercising reliable card JSON.
      "name": "Adaptive Chat Server (Ollama llama3.2, card prompt)",
      "type": "debugpy",
      "request": "launch",
      "module": "app",
      "args": [
        "--ollama-url",
        "http://127.0.0.1:11434",
        "--log-level",
        "debug",
        "--ollama-model",
        "llama3.2",
        "--system-prompt-file",
        "app/card_system_prompt.txt",
        "--json-format",
        "schema",
        "--num-ctx",
        "16384",
        "--history-turns",
        "10",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/adaptive_chat_server",
      "python": "${workspaceFolder}/adaptive_chat_server/.venv/bin/python"
    },
    {
      // Card mode: same as the gpt-oss:20b target but points the responder at
      // the bundled card system prompt (app/card_system_prompt.txt) instead of
      // the default, so the model replies with Adaptive Card fragments (date
      // pickers, choice sets, FactSet/Badge/Carousel) rendered inside the chat
      // bubble. The prompt file is re-read per request and its path is relative
      // to cwd. Echo mode ignores the system prompt, so this is Ollama-only.
      // --json-format schema is the default (docs/superpowers/specs/2026-07-23-
      // ollama-structured-json-output-design.md) but named explicitly here since
      // this target's whole purpose is exercising reliable card JSON.
      "name": "Adaptive Chat Server (Ollama gpt-oss:20b, card prompt)",
      "type": "debugpy",
      "request": "launch",
      "module": "app",
      "args": [
        "--ollama-url",
        "http://127.0.0.1:11434",
        "--log-level",
        "debug",
        "--ollama-model",
        "gpt-oss:20b",
        "--system-prompt-file",
        "app/card_system_prompt.txt",
        "--json-format",
        "schema",
        "--num-ctx",
        "16384",
        "--history-turns",
        "10",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/adaptive_chat_server",
      "python": "${workspaceFolder}/adaptive_chat_server/.venv/bin/python"
    },
    {
      // Card mode: same as the gpt-oss:20b target but points the responder at
      // the bundled card system prompt (app/card_system_prompt.txt) instead of
      // the default, so the model replies with Adaptive Card fragments (date
      // pickers, choice sets, FactSet/Badge/Carousel) rendered inside the chat
      // bubble. The prompt file is re-read per request and its path is relative
      // to cwd. Echo mode ignores the system prompt, so this is Ollama-only.
      // --json-format schema is the default (docs/superpowers/specs/2026-07-23-
      // ollama-structured-json-output-design.md) but named explicitly here since
      // this target's whole purpose is exercising reliable card JSON.
      "name": "Adaptive Chat Server (Ollama qwen3.5:9b, card prompt)",
      "type": "debugpy",
      "request": "launch",
      "module": "app",
      "args": [
        "--ollama-url",
        "http://127.0.0.1:11434",
        "--log-level",
        "debug",
        "--ollama-model",
        "qwen3.5:9b",
        "--system-prompt-file",
        "app/card_system_prompt.txt",
        "--json-format",
        "schema",
        "--num-ctx",
        "16384",
        "--history-turns",
        "10",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/adaptive_chat_server",
      "python": "${workspaceFolder}/adaptive_chat_server/.venv/bin/python"
    }
  ],
  "compounds": [
    {
      "name": "Adaptive Chat (server + web)",
      "configurations": [
        "Adaptive Chat Server (echo)",
        "Adaptive Chat Client - Web"
      ]
    },
    {
      "name": "Adaptive Chat (Ollama gpt-oss + web)",
      "configurations": [
        "Adaptive Chat Server (Ollama gpt-oss:20b)",
        "Adaptive Chat Client - Web"
      ]
    },
    {
      "name": "Adaptive Chat (card-mode Ollama gpt-oss server + web)",
      "configurations": [
        "Adaptive Chat Server (Ollama gpt-oss:20b, card prompt)",
        "Adaptive Chat Client - Web"
      ]
    },
    {
      "name": "Adaptive Chat (card-mode Ollama llama3.2 server + web)",
      "configurations": [
        "Adaptive Chat Server (Ollama llama3.2, card prompt)",
        "Adaptive Chat Client - Web"
      ]
    }
  ]
}