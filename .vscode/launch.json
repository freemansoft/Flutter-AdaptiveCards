{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Widgetbook - Current",
      "type": "dart",
      "request": "launch",
      "flutterMode": "debug",
      "cwd": "${workspaceFolder}/widgetbook",
      "program": "lib/main.dart",
      "args": []
    },
    {
      // Sections with images may fail in chrome because of HTTPS CORS issues
      // Use --disable-web-security to disable CORS
      "name": "Widgetbook - Web",
      "type": "dart",
      "request": "launch",
      "flutterMode": "debug",
      "cwd": "${workspaceFolder}/widgetbook",
      "program": "lib/main.dart",
      "args": [
        "--web-browser-flag=--disable-web-security",
        "-d",
        "chrome",
        "--web-port",
        "3000"
      ]
    },
    {
      "name": "Adaptive Explorer - Current",
      "type": "dart",
      "request": "launch",
      "flutterMode": "debug",
      "cwd": "${workspaceFolder}/adaptive_explorer",
      "program": "lib/main.dart",
      "args": []
    },
    {
      "name": "Adaptive Chat - Current",
      "type": "dart",
      "request": "launch",
      "flutterMode": "debug",
      "cwd": "${workspaceFolder}/adaptive_chat",
      "program": "lib/main.dart",
      "args": []
    },
    {
      // Talks to the FastAPI server on :8000. --disable-web-security avoids
      // local CORS friction when running the app in Chrome during development.
      "name": "Adaptive Chat - Web",
      "type": "dart",
      "request": "launch",
      "flutterMode": "debug",
      "cwd": "${workspaceFolder}/adaptive_chat",
      "program": "lib/main.dart",
      "args": [
        "--web-browser-flag=--disable-web-security",
        "-d",
        "chrome",
        "--web-port",
        "3000"
      ]
    },
    {
      // Uses the project's Python venv; run `python3 -m venv .venv &&
      // .venv/bin/pip install -r requirements.txt` in adaptive_chat_server
      // first. On Windows use .venv/Scripts/python.exe.
      "name": "Adaptive Chat Server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--port", "8000"],
      "cwd": "${workspaceFolder}/adaptive_chat_server",
      "python": "${workspaceFolder}/adaptive_chat_server/.venv/bin/python"
    }
  ],
  "compounds": [
    {
      "name": "Adaptive Chat (server + web)",
      "configurations": ["Adaptive Chat Server", "Adaptive Chat - Web"]
    }
  ]
}
