{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Use the 'Enable password reveal toggle' knob to show/hide the eye-icon.",
      "wrap": true
    },
    {
      "type": "Input.Text",
      "id": "passwordField",
      "label": "Password",
      "placeholder": "Enter your password",
      "style": "password",
      "maxLength": 64
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Sign in"
    }
  ]
}
