{
  "$defs": {
    "Element": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "TextBlock",
            "FactSet",
            "Badge",
            "Carousel",
            "Table",
            "Input.Date",
            "Input.ChoiceSet",
            "Input.Text",
            "Input.Number",
            "Input.Time",
            "Rating",
            "Icon",
            "ProgressBar",
            "ProgressRing",
            "CodeBlock",
            "Image"
          ]
        }
      }
    },
    "CardObject": {
      "type": "object",
      "required": ["type", "body"],
      "properties": {
        "type": { "const": "AdaptiveCard" },
        "version": { "type": "string" },
        "body": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Element" }
        }
      }
    },
    "ElementArray": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Element" }
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/CardObject" },
    { "$ref": "#/$defs/ElementArray" },
    { "$ref": "#/$defs/Element" },
    { "type": "string" }
  ]
}
